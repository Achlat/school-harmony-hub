# ─────────────────────────────────────────────────────────────────────────────
# ScolarPro — Configuration backend
# Copier ce fichier en .env et remplir les valeurs avant de démarrer
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de données MySQL ─────────────────────────────────────────────────────
# Format : mysql://UTILISATEUR:MOT_DE_PASSE@HOTE:PORT/NOM_BASE
DATABASE_URL="mysql://root:motdepasse@localhost:3306/scolarpr o"

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# ⚠️  Générez une clé aléatoire forte en production (min. 32 caractères)
# Exemple : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=changez-cette-cle-par-une-valeur-aleatoire-forte-en-production
JWT_EXPIRES_IN=7d

# ── CORS — URL du frontend ────────────────────────────────────────────────────
# En développement local
CORS_ORIGIN=http://localhost:5173
# En production, remplacez par l'URL réelle de votre frontend
# CORS_ORIGIN=https://votre-domaine.com
